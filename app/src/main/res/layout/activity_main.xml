<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPT 공작소 네이버 도우미"
            android:textSize="24sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="ZIP 파일을 선택해 주세요."
            android:textSize="16sp" />
        <Button
            android:id="@+id/selectZipButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="자료 ZIP 선택" />
        <Button
            android:id="@+id/accessibilityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="접근성 설정 열기" />
        <Button
            android:id="@+id/openNaverButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="네이버 블로그 글쓰기 열기" />
        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:enabled="false"
            android:text="자동입력 시작" />
        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="자동입력 즉시 중지" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="안전 기준\n• 네이버 로그인 정보는 저장하지 않습니다.\n• 게시판을 찾지 못하면 자동으로 선택하지 않습니다.\n• 발행·임시저장 버튼은 자동으로 누르지 않습니다.\n• 추가 인증이나 보안 확인이 나타나면 중단합니다."
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
